{
  "name": "chidodesigns/wordpress",
  "description": "WordPress project with Composer-managed plugins",
  "type": "project",
  "require": {
    "johnpbloch/wordpress": "^6.0",
    "wpackagist-plugin/advanced-custom-fields": "*",
    "wpackagist-plugin/custom-post-type-ui": "*",
    "wpackagist-plugin/jwt-authentication-for-wp-rest-api": "*"
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://wpackagist.org"
    }
  ],
  "extra": {
    "installer-paths": {
      "wp-content/plugins/{$name}/": ["type:wordpress-plugin"]
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0",
    "wp-phpunit/wp-phpunit": "^6.9",
    "yoast/phpunit-polyfills": "^4.0"
  },
  "config": {
    "allow-plugins": {
      "johnpbloch/wordpress-core-installer": true,
      "composer/installers": true
    }
  }
}
